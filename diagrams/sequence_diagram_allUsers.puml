@startuml Sequence Diagram - All Users Command
skinparam backgroundColor #FFE5F1
skinparam defaultFontSize 11
skinparam sequenceParticipant {
    backgroundColor #FFF0F8
    borderColor #9C27B0
}

title Sequence Diagram - allUsers Command Flow

note over user, serverModel
  **Note:** Applications started via\nLauncher.main() → TCPClient/TCPServer.main()\n(Launcher class not shown for clarity)
end note

participant "Chat User" as user
participant "CView" as view
participant "CModel" as model
participant "Socket" as socket
participant "ClientHandler" as handler
participant "SModel" as serverModel

== User requests active users ==
user -> view : Type "allUsers" or click All Users button
view -> model : requestAllUsers() or sendMessage("allUsers")
model -> socket : dos.writeUTF("allUsers")

== Server processes command ==
socket -> handler : dis.readUTF()
handler -> handler : detect "allUsers" command
handler -> serverModel : getAllUsernames()
serverModel -> serverModel : get and assemble usernames from ClientHandlers
serverModel --> handler : List<String> usernames
handler -> handler : format "list of active Users: user1, user2, ..."
handler -> socket : dos.writeUTF(userList)

== Client will receive and display ==
socket -> model : dis.readUTF() (in receiveThread)
model -> view : addMessage(userList)
view -> user : Display user list in chat area

@enduml
