@startuml Deployment Diagram
!theme plain
skinparam backgroundColor #FFE5F1
skinparam defaultFontSize 12
skinparam node {
    backgroundColor #FFF0F8
    borderColor #9C27B0
    borderThickness 2
}
skinparam artifact {
    backgroundColor #E1BEE7
    borderColor #6B2C91
}
skinparam component {
    backgroundColor #FFF0F8
    borderColor #673AB7
}

title Deployment Diagram

node "**Server Node**\n(Physical Machine)" as serverNode {
    artifact "**tcp_socket_server-1.0-SNAPSHOT.jar**\n(Shade Plugin - Executable JAR)\nMain: ma.project.Launcher" as serverJar

    component "Server Process" as serverProc {
        component [Launcher\nJAR Entry Point] as launcher
        component [TCPServer\nJavaFX Application] as tcpServer
        component [SModel\nBusiness Logic] as serverModel
        component [SView\nJavaFX UI] as serverView
        component [ClientHandler 1\nThread] as ch1
        component [ClientHandler 2\nThread] as ch2
        component [ClientHandler N\nThread] as chN
    }

    database "**server.properties**\nIP: 0.0.0.0\nPort: 3000" as config

    component "ServerSocket\n(Listening Port 3000)" as serverSocket
    
    component "JavaFX 21 Modules\n(Module Path Required)" as javafxModules
}

node "**Client Node 1**\n(Physical Machine)" as client1 {
    artifact "**tcp_socket_client-1.0-SNAPSHOT.jar**\n(Shade Plugin - Executable JAR)\nMain: ma.project.Launcher" as clientJar1

    component "Client Process" as clientProc1 {
        component [Launcher\nJAR Entry Point] as launcher1
        component [TCPClient\nJavaFX Application] as tcpClient1
        component [CModel] as clientModel1
        component [CView\nJavaFX UI] as clientView1
    }

    component "Socket\n(TCP Connection)" as socket1
    
    component "JavaFX 21 Modules\n(Module Path Required)" as javafxModules1
}

node "**Client Node 2**\n(Physical Machine)" as client2 {
    artifact "**tcp_socket_client-1.0-SNAPSHOT.jar**\n(Shade Plugin - Executable JAR)\nMain: ma.project.Launcher" as clientJar2

    component "Client Process" as clientProc2 {
        component [Launcher\nJAR Entry Point] as launcher2
        component [TCPClient\nJavaFX Application] as tcpClient2
        component [CModel] as clientModel2
        component [CView] as clientView2
    }

    component "Socket\n(TCP Connection)" as socket2
    
    component "JavaFX 21 Modules\n(Module Path Required)" as javafxModules2
}

node "**Client Node N**\n(Physical Machine)" as clientN {
    component "Socket\n(TCP Connection)" as socketN
}

' Relationships - Server startup
launcher --> tcpServer : delegates to\nmain()
tcpServer --> serverModel : uses
tcpServer --> serverView : uses
serverModel --> config : reads
serverModel --> serverSocket : creates
serverSocket --> ch1 : accepts
serverSocket --> ch2 : accepts
serverSocket --> chN : accepts

' TCP/IP Communication links (bidirectional)
serverSocket -[#2196F3,bold]-> socket1 : TCP/IP\nConnection 1
ch1 -[#2196F3]-> socket1 : readUTF/writeUTF

serverSocket -[#2196F3,bold]-> socket2 : TCP/IP\nConnection 2
ch2 -[#2196F3]-> socket2 : readUTF/writeUTF

serverSocket -[#2196F3,bold]-> socketN : TCP/IP\nConnection N

' Client Launcher relationships
launcher1 --> tcpClient1 : delegates to\nmain()
launcher2 --> tcpClient2 : delegates to\nmain()

' Deployment
serverJar ..> serverProc : deploys\n(java -jar with\nmodule path)
clientJar1 ..> clientProc1 : deploys\n(java -jar with\nmodule path)
clientJar2 ..> clientProc2 : deploys\n(java -jar with\nmodule path)

' JavaFX Module Path Dependencies
javafxModules ..> serverProc : required
javafxModules1 ..> clientProc1 : required
javafxModules2 ..> clientProc2 : required

note right of serverNode
  **Server Build & Run:**
  - Build: mvn clean package
  - JAR: target/tcp_socket_server-1.0-SNAPSHOT.jar
  - Main Class: ma.project.Launcher
  - Launcher → TCPServer.main()
  - Run: java --module-path <javafx-jars> --add-modules javafx.controls,javafx.fxml -jar tcp_socket_server-1.0-SNAPSHOT.jar
  - Config: Loaded from server.properties
  - Architecture: Thread-per-connection
end note

note right of client1
  **Client Build & Run:**
  - Build: mvn clean package
  - JAR: target/tcp_socket_client-1.0-SNAPSHOT.jar
  - Main Class: ma.project.Launcher
  - Launcher → TCPClient.main()
  - Run: java --module-path <javafx-jars> --add-modules javafx.controls,javafx.fxml -jar tcp_socket_client-1.0-SNAPSHOT.jar localhost 3000
  - Requires: JavaFX 21 modules on module path
end note

legend right
  |= Symbol |= Meaning |
  | Blue lines | TCP/IP socket connections |
  | Server | Central distributor |
  | Clients | Multiple simultaneous connections |
  | Port 3000 | Default server port |
  | JAR Files | Built with Maven Shade Plugin |
  | Launcher Class | JAR entry point (delegates to main class) |
  | JavaFX Modules | Required on module path (JavaFX 21) |
endlegend

@enduml