@startuml Sequence Diagram - Client Connection
skinparam backgroundColor #FFE5F1
skinparam defaultFontSize 11
skinparam sequenceParticipant {
    backgroundColor #FFF0F8
    borderColor #9C27B0
}

title Sequence Diagram - Client Connection

participant "JVM" as JVM
participant "Launcher" as Launcher
participant "TCPClient" as TCPClient
participant "Chat User" as User
participant "CView" as view
participant "CModel" as model
participant "Socket" as socket
participant "ServerSocket" as ServerSocket
participant "ClientHandler" as Handler
participant "SModel" as ServerModel
participant "SView" as ServerView

== Application Startup ==
JVM -> Launcher : java -jar tcp_socket_client.jar\n(Launcher.main())
activate Launcher
Launcher -> TCPClient : TCPClient.main(args)
activate TCPClient
TCPClient -> TCPClient : launch(args)\n(JavaFX Application)
TCPClient -> view : start(Stage)
activate view
view -> model : new CModel()
activate model
deactivate Launcher

== Initiating the Connection ==
user -> view : please enter username, then click Connect
view -> model : connect(serverIP, PortNumb, Username)
model -> model : set readOnly = (If username empty?)

== Establishing a TCP Connection ==
model -> socket : new Socket(serverIP, PortNumb)
activate socket
socket -> serverSocket : REQUEST A TCP connection
activate serverSocket
serverSocket -> serverSocket : accept()
serverSocket -> handler : new ClientHandler(socket)
activate handler
serverSocket -> handler : start thread

== Username  ==
model -> socket : dos.writeUTF(username or "")
socket -> handler : dis.readUTF()
handler -> handler : validate username

alt username provided
    handler -> serverModel : clientConnected(handler, username)
    serverModel -> serverModel : assign random color
    serverModel -> handler : sendMessage("Welcome [username]!")
    handler -> socket : dos.writeUTF(welcome)
    socket -> model : (receives in receiveThread)
    serverModel -> serverView : addUser(username, color)
else username empty (Read-Only Mode)
    handler -> socket : sendMessage("READ-ONLY MODE")
end

model -> view : updateStatus(true)
view -> user : Show "Online", enable chat
model -> model : start receiveThread

@enduml
